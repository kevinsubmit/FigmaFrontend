# Application Settings
APP_NAME=NailsDash API
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Server Settings
HOST=0.0.0.0
PORT=8000
WEB_CONCURRENCY=1
WEB_TIMEOUT_KEEP_ALIVE_SECONDS=5
WEB_BACKLOG=2048
WEB_LIMIT_CONCURRENCY=0
WEB_PROXY_HEADERS=True
WEB_FORWARDED_ALLOW_IPS=127.0.0.1
WEB_LOG_LEVEL=info
# Whether the web process should run the reminder/gift-card scheduler internally.
# Leave empty to auto-enable only in local/dev environments.
EMBEDDED_SCHEDULER_ENABLED=
# Background queue size for async push delivery.
ASYNC_PUSH_QUEUE_SIZE=2000
# Max number of due reminders processed per batch.
REMINDER_PROCESS_BATCH_SIZE=200
# Background queue size for async system log persistence.
ASYNC_LOG_QUEUE_SIZE=5000
# Max rows per async system log flush.
ASYNC_LOG_BATCH_SIZE=100
# Max time to wait before flushing a partial system log batch.
ASYNC_LOG_FLUSH_SECONDS=0.5

# Database Settings
# Local MySQL example:
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/nailsdash
# Docker Compose MySQL example:
DATABASE_URL=mysql+pymysql://nailsdash:nailsdash@db:3306/nailsdash
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_PRE_PING=True
# For local development with SQLite (optional)
# DATABASE_URL=sqlite:///./nailsdash.db

# JWT Settings
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3100,http://127.0.0.1:5173,http://127.0.0.1:3100,http://192.168.1.225:3000,http://192.168.1.225:5173,http://192.168.1.225:3100,https://github.com

# AWS S3 Settings (for file storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=nailsdash-uploads

# Redis Settings (for caching)
# Docker Compose example:
# REDIS_URL=redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# Email Settings (optional, for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# APNs Push Settings (iOS push notifications)
# Enable only after filling all required fields below.
APNS_ENABLED=False
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
# Option A: set key content directly (supports \n escaped newlines)
APNS_PRIVATE_KEY=
# Option B: set path to .p8 private key file
APNS_PRIVATE_KEY_PATH=
# True -> sandbox (development), False -> production
APNS_USE_SANDBOX=True
APNS_TIMEOUT_SECONDS=10

# File Upload Settings
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,gif,webp
UPLOAD_DIR=./uploads
# Upload file delivery mode: app | redirect | x_accel_redirect
UPLOAD_SERVING_MODE=app
# Used when UPLOAD_SERVING_MODE=redirect, e.g. https://cdn.example.com/uploads
UPLOADS_REDIRECT_BASE_URL=
# Used when UPLOAD_SERVING_MODE=x_accel_redirect, e.g. /_protected_uploads
UPLOADS_ACCEL_REDIRECT_PREFIX=
# Cache-Control max-age for immutable upload assets
UPLOADS_CACHE_CONTROL_SECONDS=31536000

# Upload Security (optional ClamAV)
SECURITY_ENABLE_CLAMAV=False
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=5
SECURITY_SCAN_FAIL_CLOSED=True

# Pagination Settings
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
