# Application Settings
APP_NAME=NailsDash API
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=production

# Server Settings
HOST=0.0.0.0
PORT=8000
WEB_CONCURRENCY=2
WEB_TIMEOUT_KEEP_ALIVE_SECONDS=5
WEB_BACKLOG=2048
WEB_LIMIT_CONCURRENCY=0
WEB_PROXY_HEADERS=True
WEB_FORWARDED_ALLOW_IPS=*
WEB_LOG_LEVEL=info
EMBEDDED_SCHEDULER_ENABLED=false

# Database / Cache
# Keep the password here consistent with MYSQL_PASSWORD in ../.env.prod
DATABASE_URL=mysql+pymysql://nailsdash:change-me@db:3306/nailsdash
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_PRE_PING=True
REDIS_URL=redis://redis:6379/0

# Security / Auth
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
CORS_ORIGINS=https://app.nailsdash.app,https://admin.nailsdash.app
TRUST_X_FORWARDED_FOR=False
TRUSTED_PROXY_IPS=127.0.0.1,::1

# Daily check-in
DAILY_CHECKIN_REWARD_POINTS=5
DAILY_CHECKIN_TIMEZONE=America/New_York

# Async workers / queues
ASYNC_PUSH_QUEUE_SIZE=2000
REMINDER_PROCESS_BATCH_SIZE=200
ASYNC_LOG_QUEUE_SIZE=5000
ASYNC_LOG_BATCH_SIZE=100
ASYNC_LOG_FLUSH_SECONDS=0.5

# Uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,gif,webp
UPLOAD_DIR=/app/uploads
UPLOAD_SERVING_MODE=app
UPLOADS_REDIRECT_BASE_URL=
UPLOADS_ACCEL_REDIRECT_PREFIX=
UPLOADS_CACHE_CONTROL_SECONDS=31536000

# Optional virus scanning
SECURITY_ENABLE_CLAMAV=False
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=5
SECURITY_SCAN_FAIL_CLOSED=True

# AWS S3 (optional if later moving uploads off local volume)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# APNs (optional)
APNS_ENABLED=False
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY=
APNS_PRIVATE_KEY_PATH=
APNS_USE_SANDBOX=False
APNS_TIMEOUT_SECONDS=8

# Pagination / safety controls
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
ADMIN_COUPON_BATCH_MAX_RECIPIENTS=200
ADMIN_COUPON_GRANT_MAX_FACE_VALUE=200.0
ADMIN_COUPON_GRANT_DAILY_TOTAL_FACE_VALUE=5000.0
ADMIN_GIFTCARD_ISSUE_MAX_AMOUNT=500.0
ADMIN_GIFTCARD_ISSUE_DAILY_TOTAL_AMOUNT=5000.0
BOOKING_RATE_LIMIT_PHONE_WHITELIST=
