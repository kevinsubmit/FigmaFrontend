# Public domains
APP_DOMAIN=www.nailsdash.com
ADMIN_DOMAIN=admin.nailsdash.app
API_DOMAIN=api.nailsdash.app

# Public API URL baked into frontend/admin production builds
PUBLIC_API_BASE_URL=https://api.nailsdash.app
WEB_APP_VERSION=web
ADMIN_APP_VERSION=web-admin

# TLS files mounted into /etc/nginx/certs in the nginx container.
# Use a SAN/wildcard certificate that covers APP_DOMAIN / ADMIN_DOMAIN / API_DOMAIN.
TLS_CERTS_DIR=./deploy/certs
TLS_CERT_FILE=fullchain.pem
TLS_KEY_FILE=privkey.pem

# Optional ACME webroot if you terminate Let's Encrypt directly in this host nginx layer
ACME_WEBROOT_DIR=./deploy/nginx/acme
LETSENCRYPT_EMAIL=ops@nailsdash.com
PRIMARY_CERT_DOMAIN=api.nailsdash.app

# MySQL container bootstrap
MYSQL_DATABASE=nailsdash
MYSQL_USER=nailsdash
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-password
